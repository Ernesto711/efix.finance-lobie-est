# ── Required ────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-use-openssl-rand-base64-64

# ── Email transport (escolha UMA) ───────────────────────────────
# Opção A: Resend (recomendado p/ produção, requer DNS configurado)
RESEND_API_KEY=

# Opção B: Gmail SMTP (rápido p/ MVP, usa app password do Lobie)
SMTP_USER=ernesto.otero@lobie.com.br
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# ── Email metadata ──────────────────────────────────────────────
MAIL_FROM=Lobie <noreply@lobie.com.br>

# ── Whitelist (opcional — defaults sensatos no server.js) ───────
# ALLOWED_DOMAINS=lobie.com.br,efix.finance,hausbank.com.br,patrimar.com.br
# ALLOWED_EMAILS=ernesto.otero@hausbank.com.br,...

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
